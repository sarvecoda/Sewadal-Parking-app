# Copy this file to `.env` in the same folder and fill values from
# Firebase Console → Project settings → Your apps → Web app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Required for username sign-in: same domain as Firebase Auth user emails (no @).
# Example: if users are mandeep@park.example.org and sarvesh@park.example.org, set:
# VITE_LOGIN_EMAIL_DOMAIN=park.example.org
VITE_LOGIN_EMAIL_DOMAIN=

# Optional: one-tap "Forgot password?" sends reset link to this exact Firebase user email (no UI).
# VITE_PASSWORD_RESET_EMAIL=you@yourdomain.com

# Example (project sns-parking-app-blr-d40c7 — replace APP_ID with your Web app id):
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=sns-parking-app-blr-d40c7.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=sns-parking-app-blr-d40c7
# VITE_FIREBASE_STORAGE_BUCKET=sns-parking-app-blr-d40c7.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=207838631968
# VITE_FIREBASE_APP_ID=1:207838631968:web:xxxxxxxx

# Set to "true" only if you still need the old fixed demo login (nirankar / nirankar).
# Leave unset or "false" for Firebase Email/Password (recommended).
# VITE_LEGACY_LOGIN=false
