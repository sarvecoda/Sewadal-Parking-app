rules_version = '2';

// Spark-friendly: no Cloud Functions. Keep ADMIN_UID in sync with web/src/adminConfig.ts
service cloud.firestore {
  match /databases/{database}/documents {
    function isParkingAdmin() {
      return request.auth != null && request.auth.uid == 'Ayisu6zH1OgqQ4XM9ggk6y1mpxS2';
    }

    // Access requests: anyone signed out can create a pending row; only admin reads/updates.
    match /access_requests/{id} {
      allow create: if request.auth == null
        && request.resource.data.keys().hasOnly(['email', 'note', 'status', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 120
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && (request.resource.data.note == null
            || (request.resource.data.note is string && request.resource.data.note.size() <= 800));

      allow read, update: if isParkingAdmin();
      allow delete: if false;
    }

    // Staff directory (written when admin approves). Admin full control; user can read own row.
    match /app_users/{uid} {
      allow read: if isParkingAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create, update, delete: if isParkingAdmin();
    }

    // Vehicle lists (same as Android). Any signed-in user — tighten later if needed.
    match /your_collection/{docId} {
      allow read, write: if request.auth != null;
    }

    match /your_collection1/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
