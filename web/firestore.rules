rules_version = '2';

// Spark-friendly: no Cloud Functions. Keep admin checks in sync with web/src/adminConfig.ts
service cloud.firestore {
  match /databases/{database}/documents {
    function isParkingAdmin() {
      return request.auth != null && (
        request.auth.uid == 'Ayisu6zH1OgqQ4XM9ggk6y1mpxS2' ||
        (request.auth.token.email is string
          && request.auth.token.email.lower() == 'sarveshkum9999@gmail.com')
      );
    }

    function isApprovedStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/app_users/$(request.auth.uid));
    }

    // Access requests: creator must be signed in; requestUid must match their Auth uid (password
    // was set at signup on the same project). Only admin reads/updates.
    match /access_requests/{id} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['email', 'note', 'status', 'createdAt', 'requestUid'])
        && request.resource.data.requestUid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 120
        && request.resource.data.status == 'pending'
        && (request.resource.data.note == null
            || (request.resource.data.note is string && request.resource.data.note.size() <= 800));

      allow read, update: if isParkingAdmin();
      allow delete: if false;
    }

    // Staff directory (written when admin approves). Admin full control; user can read own row.
    match /app_users/{uid} {
      allow read: if isParkingAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create, update, delete: if isParkingAdmin();
    }

    // Vehicle lists (web app; Android APK still targets your_collection / your_collection1).
    match /my_new_collection/{docId} {
      allow read, write: if isParkingAdmin() || isApprovedStaff();
    }

    match /my_new_collection_1/{docId} {
      allow read, write: if isParkingAdmin() || isApprovedStaff();
    }
  }
}
